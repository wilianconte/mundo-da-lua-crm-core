{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "mundo-da-lua-crm",
    "Audience": "mundo-da-lua-crm-clients",
    "Key": "",
    "ExpiresInMinutes": 60,
    "RefreshExpiresInDays": 7
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "HotChocolate": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/mycrm-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties}{NewLine}{Exception}"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "app", "value": "mycrm" },
            { "key": "env", "value": "production" }
          ],
          "propertiesAsLabels": [ "level" ]
        }
      }
    ]
  },
  "Resend": {
    "ApiKey": "",
    "FromEmail": "noreply@mundodalua.com.br",
    "FromName": "Mundo da Lua CRM"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  }
}
